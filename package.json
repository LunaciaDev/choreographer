{
  "name": "choreographer-web",
  "private": true,
  "version": "1.1",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite",
    "build": "bunx --bun vite build",
    "check": "bunx eslint src/js/* && bunx tsc --noEmit",
    "format": "bunx prettier src/* --write",
    "prepare": "bun .husky/install.mjs"
  },
  "devDependencies": {
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "typescript-eslint": "^8.38.0",
    "@types/bun": "latest"
  },
  "dependencies": {
    "sass": "^1.89.2",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
